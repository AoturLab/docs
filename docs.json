{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "HiLinkup Docs",
  "description": "HiLinkup API、模型与第三方应用集成文档。",
  "colors": {
    "primary": "#2563EB",
    "light": "#60A5FA",
    "dark": "#1D4ED8"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "logo": {
    "light": "/logo/hilinkup-light.svg",
    "dark": "/logo/hilinkup-dark.svg",
    "href": "https://hilinkup.com/"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "links": [
      {
        "label": "HiLinkup 主站",
        "href": "https://hilinkup.com/"
      },
      {
        "label": "控制台",
        "href": "https://hilinkup.com/console"
      }
    ],
    "primary": {
      "type": "button",
      "label": "获取 API Key",
      "href": "https://hilinkup.com/console/token"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "开始使用",
        "groups": [
          {
            "group": "入门",
            "icon": "rocket",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/authentication",
              "getting-started/openai-compatible"
            ]
          },
          {
            "group": "核心能力",
            "icon": "book-open",
            "pages": [
              "guides/model-selection",
              "guides/streaming",
              "guides/function-calling"
            ]
          },
          {
            "group": "可靠性",
            "icon": "route",
            "pages": [
              "routing/overview",
              "routing/fallbacks",
              "guides/error-handling"
            ]
          }
        ]
      },
      {
        "tab": "API 参考",
        "groups": [
          {
            "group": "API 基础",
            "pages": [
              "api-reference/introduction",
              "api-reference/models"
            ]
          },
          {
            "group": "常用 API",
            "pages": [
              "api-reference/chat-completions",
              "api-reference/embeddings",
              "api-reference/images"
            ]
          }
        ]
      },
      {
        "tab": "集成指南",
        "groups": [
          {
            "group": "接入总览",
            "icon": "blocks",
            "pages": [
              "integrations/overview"
            ]
          },
          {
            "group": "开发工具",
            "icon": "terminal",
            "pages": [
              "integrations/claude-code",
              "integrations/cursor",
              "integrations/cline",
              "integrations/openclaw"
            ]
          },
          {
            "group": "聊天客户端",
            "icon": "messages-square",
            "pages": [
              "integrations/cherry-studio",
              "integrations/chatbox",
              "integrations/lobe-chat",
              "integrations/open-webui"
            ]
          },
          {
            "group": "应用框架",
            "icon": "workflow",
            "pages": [
              "integrations/dify",
              "integrations/langchain"
            ]
          }
        ]
      },
      {
        "tab": "平台与帮助",
        "groups": [
          {
            "group": "账户与平台",
            "icon": "settings",
            "pages": [
              "platform/billing",
              "platform/rate-limits",
              "platform/security"
            ]
          },
          {
            "group": "问题排查",
            "icon": "life-buoy",
            "pages": [
              "troubleshooting/errors"
            ]
          },
          {
            "group": "更新",
            "icon": "history",
            "pages": [
              "changelog"
            ]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "api": {
    "playground": {
      "display": "simple"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript"
      ],
      "defaults": "required"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "search": {
    "prompt": "搜索 HiLinkup API、模型、SDK 和错误排查"
  },
  "metadata": {
    "timestamp": true
  },
  "footer": {
    "socials": {
      "website": "https://hilinkup.com"
    },
    "links": [
      {
        "header": "开发者",
        "items": [
          {
            "label": "快速开始",
            "href": "https://hilinkup.com/docs/getting-started/quickstart"
          },
          {
            "label": "API 参考",
            "href": "https://hilinkup.com/docs/api-reference/introduction"
          }
        ]
      },
      {
        "header": "HiLinkup",
        "items": [
          {
            "label": "官方网站",
            "href": "https://hilinkup.com/"
          },
          {
            "label": "控制台",
            "href": "https://hilinkup.com/console"
          },
          {
            "label": "API Key",
            "href": "https://hilinkup.com/console/token"
          }
        ]
      }
    ]
  },
  "errors": {
    "404": {
      "title": "页面不存在",
      "description": "检查地址，或使用搜索查找相关文档。"
    }
  }
}
