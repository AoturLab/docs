  },
  "icons": {
    "library": "lucide"
  },
  "background": {
    "decoration": "gradient"
  },
  "logo": {
    "light": "/logo/hilinkup-light.svg",
    "dark": "/logo/hilinkup-dark.svg",
    "href": "https://hilinkup.com/"
  },
  "favicon": "/favicon.svg",
